# ── Firebase web config ──────────────────────────────────────────────────────
# The rugby platform runs on the CONSOLIDATED match-pulse-4560e Firebase project
# (shared by all MatchPulse sites for unified authentication). Get these values
# from: Firebase Console → Project Settings → Your apps → the rugby Web app, and
# add them as GitHub Actions secrets (Settings → Secrets and variables →
# Actions) named exactly as below.
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=match-pulse-4560e.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=match-pulse-4560e
VITE_FIREBASE_STORAGE_BUCKET=match-pulse-4560e.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Named Firestore database rugby uses INSIDE the shared project so its data is
# separate from hockey's (which uses the project's (default) database). Defaults
# to "rugby" when unset; must match functions/.env FIRESTORE_DATABASE_ID and
# firebase.json's firestore.database. The database must be created in the
# Firebase console (Firestore → add database) before the app can read/write.
VITE_FIREBASE_DATABASE_ID=rugby

# Web push (optional until launch) — see src/lib/notifications.js
VITE_FIREBASE_VAPID_KEY=

# ── Public site ──────────────────────────────────────────────────────────────
# The canonical public origin (no trailing slash). The domain for Match Pulse
# Rugby is NOT decided yet — leave unset for previews (relative URLs are used)
# and set it here + in functions/.env (PUBLIC_BASE_URL) once chosen.
VITE_PUBLIC_BASE_URL=

# ── Billing (all optional until the rugby product takes payments) ────────────
# NEVER copy another Match Pulse product's payment links or bank details.
VITE_BILLING_EMAIL=
VITE_BILLING_BANK_NAME=
VITE_BILLING_ACCOUNT_HOLDER=
VITE_BILLING_ACCOUNT_NUMBER=
VITE_BILLING_BRANCH_CODE=
VITE_BILLING_ACCOUNT_TYPE=
VITE_PAYFAST_LINK_EVENT=
VITE_PAYFAST_LINK_PRO=

# Cloudflare Turnstile (contact form captcha) — optional pre-launch
VITE_TURNSTILE_SITE_KEY=
