# Cloud Functions runtime config (Firebase loads functions/.env at deploy).
# The rugby platform's domain is not decided yet — set PUBLIC_BASE_URL once it
# is; until then links fall back to the project's <project-id>.web.app origin.
PUBLIC_BASE_URL=
# Outbound email (Resend) — the rugby platform's own sender + inbox.
RESEND_API_KEY=
EMAIL_FROM=MatchPulse Rugby <noreply@your-domain>
CONTACT_EMAIL=
# Cloudflare Turnstile secret (contact form captcha)
TURNSTILE_SECRET_KEY=
# Optional override for the SSR shell fetch (defaults to <project>.web.app)
SHELL_URL=
